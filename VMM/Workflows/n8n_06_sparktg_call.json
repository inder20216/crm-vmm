      "parameters": {
        "jsCode": "const raw  = $input.first().json;\nconst body = raw.body || raw || {};\nconst number = body.number;\n\nif (!number) {\n  return [{ json: { error: 'number is required' } }];\n}\n\nconst username  = '10167201';\nconst password  = 'agent007';\nconst serviceId = '1672';\nconst did       = '01205136387';\n\nconst clean = String(number).replace(/\\D/g, '');\nconst authHeader = 'Basic ' + Buffer.from(username + ':' + password).toString('base64');\n\nconst bodyStr = 'number='          + encodeURIComponent(clean)\n  + '&service-id='                 + encodeURIComponent(serviceId)\n  + '&agent-dial-first=true'\n  + '&recording=true'\n  + (did ? '&did=' + encodeURIComponent(did) : '');\n\nreturn [{ json: { authHeader, bodyStr, number: clean } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 352],
      "id": "fu06-node-0002",
