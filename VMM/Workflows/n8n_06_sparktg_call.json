    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst callId = result.id || result.callTxnId || result.call_id || null;\nreturn [{ json: { success: true, callId, raw: result } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 280],
