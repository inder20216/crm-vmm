      "parameters": {
        "jsCode": "const err = $input.first().json;\nconst msg = err.message || err.description || err.errorMessage || 'SparkTG error';\n// Clean up common SparkTG error messages for the agent\nconst friendly = msg.includes('busy') ? 'Agent is busy — wait a moment and try again'\n  : msg.includes('number') ? 'Invalid phone number'\n  : msg.includes('service') ? 'SparkTG service error — check credentials'\n  : msg;\nreturn [{ json: { success: false, error: friendly, raw: err } }];"
