    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nreturn [{ json: { success: true, count: rows.length, requests: rows } }];",
        "mode": "runOnceForAllItems"
      },
      "type": "n8n-nodes-base.code",
