        "query": "SELECT r.id, r.store_code, r.store_name, r.request_date, r.received_date, r.email_from, r.email_subject, r.status, r.total_items, r.escalated_at, r.escalated_to, r.created_at FROM vmm_ntr_requests r ORDER BY r.created_at DESC LIMIT 200",
