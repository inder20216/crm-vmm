  "name": "VMM SP — AMC Vendor Lookup",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "vmm-sp-amc-vendor",
        "responseMode": "responseNode",
        "options": { "allowedOrigins": "*" }
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 400],
      "id": "amc-node-0001",
      "name": "Webhook — GET /vmm-sp-amc-vendor",
      "webhookId": "vmm-sp-amc-vendor"
    },
    {
      "parameters": {
        "jsCode": "const query   = $input.first().json.query || {};\nconst product = (query.product || '').toString().trim().toLowerCase();\n\n// Normalise the incoming product name to one of the 4 known AMC categories\nconst AC_NAMES          = ['ac', 'air conditioner', 'air conditioning', 'a/c', 'server room ac', 'air curtain'];\nconst LIFT_NAMES        = ['lift', 'elevator', 'lifts', 'elevators', 'escalator'];\nconst SENSORMATIC_NAMES = ['sensormatic', 'eas', 'anti-theft'];\nconst PESTCONTROL_NAMES = ['pest control', 'pest', 'fumigation'];\n\nlet category = 'unknown';\nif (AC_NAMES.some(n => product.includes(n) || n.includes(product)))          category = 'ac';\nelse if (LIFT_NAMES.some(n => product.includes(n) || n.includes(product)))   category = 'lift';\nelse if (SENSORMATIC_NAMES.some(n => product.includes(n) || n.includes(product))) category = 'sensormatic';\nelse if (PESTCONTROL_NAMES.some(n => product.includes(n) || n.includes(product))) category = 'pestcontrol';\n\nreturn [{ json: { ...($input.first().json), _category: category, _storeCode: (query.storeCode || '').trim().toUpperCase(), _product: product } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 400],
      "id": "amc-node-0002",
      "name": "Classify Product"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json._category }}", "rightValue": "ac", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json._category }}", "rightValue": "lift", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json._category }}", "rightValue": "sensormatic", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json._category }}", "rightValue": "pestcontrol", "operator": { "type": "string", "operation": "equals" } }] } }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [680, 400],
