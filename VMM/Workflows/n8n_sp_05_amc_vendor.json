    {
      "parameters": {
        "jsCode": "// Runs after each sheet read — finds the row matching storeCode and returns vendor + vendorEmail.\n// Works for all 4 product sheets as long as columns are: Store Code, Vendor, Vendor Email\n// (column names are flexible — see aliases below)\n\nconst classify = $('Classify Product').first().json;\nconst storeCode = classify._storeCode || '';\nconst product   = classify._product   || '';\nconst category  = classify._category  || '';\n\nif (!storeCode) {\n  return [{ json: { found: false, message: 'storeCode is required' } }];\n}\n\nconst all = $input.all();\n\n// Flexible column name lookup\nfunction col(row, ...names) {\n  for (const n of names) {\n    const val = (row[n] || '').toString().trim();\n    if (val) return val;\n  }\n  return '';\n}\n\nconst match = all.find(item => {\n  const rowCode = col(item.json, 'Store Code', 'StoreCode', 'store_code', 'Code').toUpperCase();\n  return rowCode === storeCode;\n});\n\nif (!match) {\n  return [{ json: { found: false, storeCode, product, category, message: 'No AMC vendor on record for this store' } }];\n}\n\nconst vendor      = col(match.json, 'Vendor', 'Vendor Name', 'vendor_name', 'Company');\nconst vendorEmail = col(match.json, 'Vendor Email', 'Email', 'vendor_email', 'Contact Email');\nconst vendorPhone = col(match.json, 'Vendor Phone', 'Phone', 'Mobile', 'Contact No');\n\nreturn [{ json: { found: true, vendor, vendorEmail, vendorPhone, storeCode, product, category } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 400],
      "id": "amc-node-0008",
      "name": "Match & Return Vendor"
    },
    {
      "parameters": {
        "jsCode": "// Fallback — product not in any AMC category\nconst classify = $('Classify Product').first().json;\nreturn [{ json: { found: false, storeCode: classify._storeCode, product: classify._product, message: 'No AMC vendor data for this product type' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 800],
      "id": "amc-node-0009",
      "name": "Unknown Product"
